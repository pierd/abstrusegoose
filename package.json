{
  "name": "abstruse-goose",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "parse-pages": "uv run python parse_page.py raw/abstrusegoose.com/{1..611}.html raw/abstrusegoose.com/secretarchives/* > src/strips.json",
